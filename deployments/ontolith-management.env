# Ontolith management server environment (systemd EnvironmentFile)
# Install to: /etc/ontolith/ontolith-management.env

# Management API listen address
ONTOLITH_MANAGEMENT_BIND=127.0.0.1:9091

# Runtime bind metadata shown in management views.
ONTOLITH_BIND=127.0.0.1:8080

# Storage: memory | rocksdb
ONTOLITH_STORAGE=memory
# Used when ONTOLITH_STORAGE=rocksdb
ONTOLITH_DATA_DIR=/var/lib/ontolith/data

# Auth: disabled | enforced
ONTOLITH_AUTH_MODE=disabled
# Required when AUTH_MODE=enforced
# ONTOLITH_API_KEY=change-me

# Optional management ACL split.
# ONTOLITH_MANAGEMENT_READ_KEY=read-key
# ONTOLITH_MANAGEMENT_WRITE_KEY=write-key

# Runtime probe timeout (ms) for probing ONTOLITH_BIND.
# ONTOLITH_MANAGEMENT_PROBE_TIMEOUT_MS=300

# Optional durable audit JSONL path.
# ONTOLITH_AUDIT_PATH=/var/lib/ontolith/data/audit.jsonl
